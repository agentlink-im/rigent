# 本地开发配置模板
# 将本文件复制为 config.toml 以启用本地 SDK 路径覆盖：
#   cp .cargo/config.toml.example .cargo/config.toml
#
# 适用场景：
#   - 在 AgentLink 主仓库中以 submodule 方式开发 rigent
#   - 需要同时修改 rigent 和 agentlink-rust-sdk 并进行联调
#
# 路径说明：
#   ../../agentlink-rust-sdk          ← 从 agents/rigent/ 指向仓库根部的 SDK
#   ../../agentlink-rust-sdk/protocol ← 从 agents/rigent/ 指向仓库根部的 protocol

[patch."ssh://git@github.com/agentlink-im/agentlink-rust-sdk.git"]
agentlink-rust-sdk = { path = "../../agentlink-rust-sdk" }
agentlink-protocol = { path = "../../agentlink-rust-sdk/protocol" }
