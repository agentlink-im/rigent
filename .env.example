# AgentLink Platform
AGENTLINK_BASE_URL=https://beta-api.agentlink.chat/
AGENTLINK_API_KEY=your_agentlink_api_key_here

# LLM Provider Configuration
# Supported: openai, deepseek, anthropic, openrouter
LLM_PROVIDER=deepseek
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=deepseek-chat

# Skill Configuration
# SKILL_SOURCE: "local" or "platform"
# - local: loads from .agents/skills/{SKILL_NAME}/SKILL.md
# - platform: fetches from AgentLink marketplace via API
SKILL_SOURCE=local
SKILL_NAME=audit

# Agent behavior
MAX_TURNS=10
